# =============================================================
# YKS/LGS Koçluk Asistanı — Ortam Değişkenleri Şablonu
# =============================================================
# Bu dosyayı kopyalayıp ".env" adıyla kaydedin:
#   cp .env.example .env
# Gerçek değerleri girdikten sonra .env'i .gitignore'a ekleyin —
# API anahtarlarını asla Git'e commit etmeyin!
# =============================================================

# ─────────────────────────────────────────────────────────────
# ZORUNLU — Google Gemini API Anahtarları
# https://aistudio.google.com/app/apikey adresinden alın.
# En az biri girilmeli; ikisi de varsa otomatik yük dengeleme aktif.
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY_1=AIzaSy_BURAYA_GERCEK_KEY_1_YAZIN
GEMINI_API_KEY_2=AIzaSy_BURAYA_GERCEK_KEY_2_YAZIN

# ─────────────────────────────────────────────────────────────
# İSTEĞE BAĞLI — CORS (production'da kısıtlayın)
# Örnek: https://uygulamaniz.com,https://www.uygulamaniz.com
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────────────────────
# İSTEĞE BAĞLI — Yedek LLM Sağlayıcılar
# ─────────────────────────────────────────────────────────────
# GROQ_API_KEY=gsk_BURAYA_GROQ_KEY_YAZIN
# OPENAI_API_KEY=sk-BURAYA_OPENAI_KEY_YAZIN

# ─────────────────────────────────────────────────────────────
# Render Deploy — Start Command:
#   uvicorn api:app --host 0.0.0.0 --port $PORT
# Build Command:
#   pip install -r requirements.txt
# ─────────────────────────────────────────────────────────────